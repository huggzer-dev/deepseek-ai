{
  "name": "deepseek-ai",
  "version": "0.1.0",
  "description": "deepseek-ai for obsidian",
  "main": "main.js",
  "type": "module",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "lint": "tsc -noEmit -skipLibCheck",
    "typecheck": "tsc -noEmit -skipLibCheck",
    "test": "node --test --import tsx 'tests/unit/*.test.ts'",
    "test:unit": "node --test --import tsx 'tests/unit/*.test.ts'",
    "test:smoke": "node tests/smoke/run-smoke.mjs",
    "verify": "npm run typecheck && npm run test && npm run test:smoke"
  },
  "keywords": [
    "obsidian",
    "deepseek",
    "ai",
    "agent"
  ],
  "author": "huggzer-dev",
  "license": "MIT",
  "homepage": "https://github.com/huggzer-dev/deepseek-ai",
  "repository": {
    "type": "git",
    "url": "https://github.com/huggzer-dev/deepseek-ai.git"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "esbuild": "^0.24.0",
    "obsidian": "latest",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
